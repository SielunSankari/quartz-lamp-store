rules_version = '2';

// Правила безопасности Firestore — это «охрана» базы данных.
// Клиентский Firebase SDK подчиняется этим правилам; Admin SDK (сервер) — нет.
service cloud.firestore {
  match /databases/{database}/documents {

    // Товары: читать может любой (каталог публичный), писать — никто с клиента.
    // Товары добавляются только через сид-скрипт / консоль (Admin SDK).
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // Корзина: только её владелец (вошедший пользователь со своим uid).
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Заказы создаёт и читает их владелец. Менять статус (оплачен/нет)
    // разрешено только серверу (Admin SDK), поэтому update/delete с клиента запрещены.
    match /orders/{orderId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Отзывы: читают все. Документ = reviews/{uid} → один отзыв на аккаунт,
    // писать/править/удалять можно только свой, с валидацией оценки и текста.
    match /reviews/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.data.userId == userId
                            && request.resource.data.rating is number
                            && request.resource.data.rating >= 1
                            && request.resource.data.rating <= 5
                            && request.resource.data.text is string
                            && request.resource.data.text.size() > 0
                            && request.resource.data.text.size() <= 600;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
