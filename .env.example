# ============================================================================
#  ШАБЛОН переменных окружения.
#  Скопируй этот файл в .env.local и заполни реальными значениями.
#  .env.local НЕ коммитится в git (см. .gitignore).
#
#  Команда: cp .env.example .env.local
# ============================================================================

# --- Firebase (клиент) -------------------------------------------------------
# Firebase Console → ⚙ Project settings → General → Your apps → Web app → SDK config.
# Это ПУБЛИЧНЫЕ ключи (попадают в браузер) — их безопасно держать на клиенте,
# доступ к данным ограничивают Firestore Security Rules, а не эти ключи.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (сервер) -------------------------------------------------
# Firebase Console → ⚙ Project settings → Service accounts → Generate new private key.
# Из скачанного JSON возьми три поля. ВАЖНО: private_key оберни в кавычки,
# переводы строк оставь как \n (одной строкой).
FIREBASE_PROJECT_ID=your-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Stripe (онлайн-оплата) --------------------------------------------------
# https://dashboard.stripe.com/apikeys (для разработки используй ключи Test mode).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Секрет вебхука: stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Прочее ------------------------------------------------------------------
# Базовый URL приложения (для редиректов Stripe). Локально — http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Arcjet (защита от ботов, опционально): https://launch.arcjet.com
ARCJET_KEY=
