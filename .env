# Этот файл коммитится в git — здесь ТОЛЬКО несекретные значения по умолчанию.
# Реальные ключи (Firebase, Stripe, Arcjet) клади в .env.local — он игнорируется git.
# Полный список переменных и инструкция — в .env.example

# Sentry
SENTRY_SPOTLIGHT=false
# Disable Sentry warning with TurboPack
SENTRY_SUPPRESS_TURBOPACK_WARNING=1

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
